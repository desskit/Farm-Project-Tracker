# --- Core ---
# Public origin the app is served from (used for invite/QR links, cookies).
PUBLIC_URL=https://farm.example.com
# Domain Caddy serves + gets a TLS cert for (host only, no scheme).
PUBLIC_DOMAIN=farm.example.com
# Process timezone — set to the farm's zone so "today"/rollovers match the crew.
TZ=America/Los_Angeles
# Secret used to sign/verify session material. Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-hex-string

# --- Database ---
# libsql/SQLite file. In Docker this lives on the mounted /data volume.
DATABASE_URL=file:./data/app.db

# --- File storage ---
# Directory for uploaded photos/documents (mounted volume in Docker).
UPLOAD_DIR=./data/uploads

# --- Email (digests) — optional; digests are skipped if unset ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Farm Tracker <farm@example.com>"

# --- Web Push (VAPID) — optional; push is skipped if unset ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- AI "Suggest steps" — optional; button hidden if unset ---
ANTHROPIC_API_KEY=

# --- Seed admin (first run only) ---
SEED_ADMIN_NAME=Dale
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
