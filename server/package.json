{
  "name": "farm-project-tracker-server",
  "version": "0.1.0",
  "private": true,
  "description": "Server-phase (Next.js) rewrite of the Farm Project Tracker.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
